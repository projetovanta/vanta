# Copie este arquivo para .env.local e preencha com suas credenciais

# Supabase Cloud
VITE_SUPABASE_URL=https://[seu-project-id].supabase.co
VITE_SUPABASE_ANON_KEY=[sua-anon-key]

# Firebase (opcional — pra notificações)
VITE_FIREBASE_PROJECT_ID=seu-project-id
VITE_FIREBASE_API_KEY=sua-api-key
VITE_FIREBASE_AUTH_DOMAIN=seu-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://seu-project.firebaseio.com
VITE_FIREBASE_STORAGE_BUCKET=seu-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=seu-sender-id
VITE_FIREBASE_APP_ID=seu-app-id
VITE_FIREBASE_MEASUREMENT_ID=seu-measurement-id

# Meta API (opcional — pra verificação automática posts)
VITE_META_ACCESS_TOKEN=seu-token-permanente
VITE_INSTAGRAM_BUSINESS_ACCOUNT_ID=seu-account-id
