{
  "name": "vanta",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts tests/unit",
    "test:integration": "vitest run --config vitest.config.ts tests/integration",
    "test:watch": "vitest --config vitest.config.ts",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint src/ modules/ features/ hooks/ services/ --quiet",
    "lint:layout": "node scripts/lint-layout.mjs",
    "lint:all": "tsc --noEmit && eslint src/ modules/ features/ hooks/ services/ --quiet && node scripts/lint-layout.mjs",
    "preflight": "node scripts/preflight.mjs && touch /tmp/vanta_preflight_passed",
    "explore": "node scripts/explore.mjs",
    "audit": "node scripts/audit.mjs",
    "deep-audit": "node scripts/deep-audit.mjs",
    "memory-audit": "node scripts/memory-audit.mjs",
    "memory-audit-deep": "node scripts/memory-audit-deep.mjs",
    "diff-check": "node scripts/diff-check.mjs",
    "deps": "node scripts/deps.mjs",
    "store-map": "node scripts/store-map.mjs",
    "lines": "node scripts/lines.mjs",
    "props": "node scripts/props.mjs",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'modules/**/*.{ts,tsx}' 'features/**/*.{ts,tsx}' 'hooks/**/*.{ts,tsx}' 'services/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'modules/**/*.{ts,tsx}' 'features/**/*.{ts,tsx}' 'hooks/**/*.{ts,tsx}' 'services/**/*.{ts,tsx}'",
    "knip": "knip",
    "analyze": "ANALYZE=true vite build",
    "lighthouse": "lighthouse http://localhost:5173 --output html --output-path ./lighthouse-report.html --chrome-flags='--headless=new'",
    "preview": "vite preview",
    "prepare": "husky",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "generate-icons": "node scripts/generate-icons.mjs",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "security-scan": "bash scripts/security-scan.sh",
    "bundle-audit": "bash scripts/bundle-audit.sh",
    "store-readiness": "bash scripts/store-readiness.sh",
    "bridge-audit": "bash scripts/capacitor-bridge-audit.sh",
    "privacy-audit": "bash scripts/app-privacy-audit.sh",
    "design-audit": "bash scripts/design-audit.sh",
    "full-audit": "bash full-audit.sh",
    "depcheck": "depcheck --ignores='@capacitor/*,@sentry/*,@tailwindcss/*,@types/*,terser,husky' .",
    "type-coverage": "type-coverage --at-least 80 --strict --detail --ignore-files 'dist/**' --ignore-files 'node_modules/**' --ignore-files 'tests/**'",
    "ncu": "ncu",
    "ncu:minor": "ncu --target minor",
    "db:diff": "npx supabase db diff --use-migra",
    "bundle-viz": "npx vite-bundle-visualizer"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/push-notifications": "^8.0.1",
    "@sentry/react": "^10.42.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-virtual": "^3.13.19",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "exceljs": "^4.4.0",
    "firebase": "^12.9.0",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.574.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.6",
    "react-helmet-async": "^3.0.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "terser": "^5.46.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^5.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^4.0.18",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lighthouse": "^13.0.3",
    "lint-staged": "^16.3.0",
    "npm-check-updates": "^19.6.3",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.0",
    "supabase": "^2.76.15",
    "tailwindcss": "^4.2.1",
    "type-coverage": "^2.29.7",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "workbox-window": "^7.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --quiet --fix"
    ]
  },
  "overrides": {
    "dompurify": ">=3.3.2"
  }
}
